{
  "name": "@typecaast/builder",
  "version": "0.1.0",
  "description": "Embeddable visual builder for Typecaast configs (source-available, FSL-1.1-Apache-2.0).",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@typecaast/core": "workspace:*",
    "@typecaast/react": "workspace:*",
    "@typecaast/schema": "workspace:*",
    "@typecaast/skin-kit": "workspace:*",
    "@typecaast/ui": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@typecaast/skins": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
