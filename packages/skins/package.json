{
  "name": "@typecaast/skins",
  "version": "0.0.0",
  "description": "Built-in Typecaast skins (Slack, …).",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "rm -rf dist .turbo storybook-static"
  },
  "dependencies": {
    "@typecaast/core": "workspace:*",
    "@typecaast/schema": "workspace:*",
    "@typecaast/skin-kit": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "zod": "^4"
  },
  "devDependencies": {
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@typecaast/react": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.4.7",
    "vite": "^6.0.0",
    "zod": "^4.0.0"
  }
}
