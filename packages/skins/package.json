{
  "name": "@typecaast/skins",
  "version": "0.3.2",
  "description": "Built-in Typecaast skins (Slack, …).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/corywatilo/typecaast.git",
    "directory": "packages/skins"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./slack": {
      "types": "./dist/slack/index.d.ts",
      "import": "./dist/slack/index.js",
      "require": "./dist/slack/index.cjs"
    },
    "./telegram": {
      "types": "./dist/telegram/index.d.ts",
      "import": "./dist/telegram/index.js",
      "require": "./dist/telegram/index.cjs"
    },
    "./claude-code": {
      "types": "./dist/claude-code/index.d.ts",
      "import": "./dist/claude-code/index.js",
      "require": "./dist/claude-code/index.cjs"
    },
    "./imessage": {
      "types": "./dist/imessage/index.d.ts",
      "import": "./dist/imessage/index.js",
      "require": "./dist/imessage/index.cjs"
    },
    "./whatsapp": {
      "types": "./dist/whatsapp/index.d.ts",
      "import": "./dist/whatsapp/index.js",
      "require": "./dist/whatsapp/index.cjs"
    },
    "./cursor": {
      "types": "./dist/cursor/index.d.ts",
      "import": "./dist/cursor/index.js",
      "require": "./dist/cursor/index.cjs"
    },
    "./messages-macos": {
      "types": "./dist/messages-macos/index.d.ts",
      "import": "./dist/messages-macos/index.js",
      "require": "./dist/messages-macos/index.cjs"
    },
    "./discord": {
      "types": "./dist/discord/index.d.ts",
      "import": "./dist/discord/index.js",
      "require": "./dist/discord/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "clean": "rm -rf dist .turbo storybook-static"
  },
  "dependencies": {
    "@typecaast/core": "workspace:*",
    "@typecaast/schema": "workspace:*",
    "@typecaast/skin-kit": "workspace:*",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.4.7",
    "vite": "^6.0.0",
    "zod": "^4.0.0"
  }
}
