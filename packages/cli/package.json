{
  "name": "@typecaast/cli",
  "version": "0.1.6",
  "description": "Typecaast command line: validate / render / scaffold-skin.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/corywatilo/typecaast.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "typecaast": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@typecaast/capture": "workspace:*",
    "@typecaast/remotion": "workspace:*",
    "@typecaast/schema": "workspace:*",
    "cac": "^6.7.14"
  }
}
