# Copy to .env (git-ignored) and fill in. NEVER commit real values.
# This repo is public — all real secrets live in CI/host env only (§29).

# --- Publishable (client-side, safe to ship in the site build) ---
# PostHog project API key — publishable by design.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- Secret (CI/host env only — never in the repo) ---
# PostHog personal API key (MCP/admin, dashboards-as-code).
POSTHOG_PERSONAL_API_KEY=

# Vercel / Cloudflare provisioning tokens (ops only).
VERCEL_TOKEN=
CLOUDFLARE_API_TOKEN=

# Stripe (future paid render service — lives in private typecaast-cloud repo).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
